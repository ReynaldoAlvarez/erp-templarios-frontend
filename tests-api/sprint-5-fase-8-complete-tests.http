###
### SPRINT 5 - FASE 8: PRUEBAS Y AJUSTES
### REST Client Tests - Todos los endpoints del Sprint 5
### Repositorio: erp-api-templarios
### Autor: Sistema Automatizado
### Fecha: 2025-04-04
###

@baseUrl = http://localhost:3001/api/v1
@accessToken = {{login.response.body.$.data.accessToken}}

### ==========================================
### AUTENTICACIÓN
### ==========================================

### Login para obtener token
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@templarios.com",
  "password": "Admin123!"
}

### ==========================================
### FASE 2: DOCUMENT TYPES (Tipos de Documento)
### ==========================================

### Obtener todos los tipos de documento
# @name getDocumentTypes
GET {{baseUrl}}/document-types?page=1&limit=10
Authorization: Bearer {{accessToken}}

### Respuesta esperada para el frontend:
# {
#   "success": true,
#   "status": "success",
#   "message": "Tipos de documento obtenidos correctamente",
#   "data": {
#     "data": [
#       {
#         "id": "uuid",
#         "code": "MIC",
#         "name": "Manifiesto Internacional de Carga",
#         "description": "Documento aduanero principal...",
#         "isRequired": true,
#         "isForSupportOnly": false,
#         "order": 1,
#         "isActive": true,
#         "createdAt": "2025-01-01T00:00:00.000Z",
#         "updatedAt": "2025-01-01T00:00:00.000Z"
#       },
#       ...
#     ],
#     "pagination": {
#       "page": 1,
#       "limit": 10,
#       "total": 6,
#       "totalPages": 1
#     }
#   }
# }

### Obtener tipos de documento activos
# @name getActiveDocumentTypes
GET {{baseUrl}}/document-types/active
Authorization: Bearer {{accessToken}}

### Respuesta esperada:
# {
#   "success": true,
#   "data": [
#     { "id": "uuid", "code": "MIC", "name": "...", ... },
#     ...
#   ]
# }

### Obtener tipos de documento requeridos
# @name getRequiredDocumentTypes
GET {{baseUrl}}/document-types/required
Authorization: Bearer {{accessToken}}

### Obtener un tipo de documento por ID
# @name getDocumentTypeById
GET {{baseUrl}}/document-types/{{documentTypeId}}
Authorization: Bearer {{accessToken}}

### Crear un nuevo tipo de documento
# @name createDocumentType
POST {{baseUrl}}/document-types
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "code": "CUSTOM_DOC",
  "name": "Documento Personalizado",
  "description": "Descripción del documento personalizado",
  "isRequired": false,
  "isForSupportOnly": false,
  "order": 10
}

### Respuesta esperada:
# {
#   "success": true,
#   "status": "success",
#   "message": "Tipo de documento creado correctamente",
#   "data": {
#     "id": "uuid",
#     "code": "CUSTOM_DOC",
#     "name": "Documento Personalizado",
#     ...
#   }
# }

### Actualizar un tipo de documento
# @name updateDocumentType
PUT {{baseUrl}}/document-types/{{documentTypeId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Documento Personalizado Actualizado",
  "order": 11
}

### Eliminar un tipo de documento (soft delete)
# @name deleteDocumentType
DELETE {{baseUrl}}/document-types/{{documentTypeId}}
Authorization: Bearer {{accessToken}}

### ==========================================
### FASE 3: TRAMOS (Rutas Predefinidas)
### ==========================================

### Obtener todos los tramos
# @name getTramos
GET {{baseUrl}}/tramos?page=1&limit=10
Authorization: Bearer {{accessToken}}

### Respuesta esperada para el frontend:
