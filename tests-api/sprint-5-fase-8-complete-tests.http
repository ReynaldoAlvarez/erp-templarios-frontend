### Filtrar reportes por estado de pago
# @name getTripReportsByPaymentStatus
GET {{baseUrl}}/trip-reports?paymentStatus=pending&page=1&limit=10
Authorization: Bearer {{accessToken}}

### Filtrar reportes por documentos completos
# @name getTripReportsByDocsComplete
GET {{baseUrl}}/trip-reports?documentsComplete=false&page=1&limit=10
Authorization: Bearer {{accessToken}}

### Filtrar reportes por pago bloqueado
# @name getTripReportsBlockedPayments
GET {{baseUrl}}/trip-reports?isPaymentBlocked=true&page=1&limit=10
Authorization: Bearer {{accessToken}}

### Filtrar reportes por número de BL
# @name getTripReportsByBlNumber
GET {{baseUrl}}/trip-reports?blNumber=BL-2025-001
Authorization: Bearer {{accessToken}}

### Filtrar reportes por cliente
# @name getTripReportsByClient
GET {{baseUrl}}/trip-reports?clientId={{clientId}}&page=1&limit=10
Authorization: Bearer {{accessToken}}

### Obtener un reporte por ID
# @name getTripReportById
GET {{baseUrl}}/trip-reports/{{tripReportId}}
Authorization: Bearer {{accessToken}}

### Obtener un reporte por tripId
# @name getTripReportByTripId
GET {{baseUrl}}/trip-reports/trip/{{tripId}}
Authorization: Bearer {{accessToken}}

### Obtener un reporte por MIC/DTA
# @name getTripReportByMicDta
GET {{baseUrl}}/trip-reports/mic-dta/MIC-2025-001
Authorization: Bearer {{accessToken}}

### Obtener reportes con pagos bloqueados
# @name getBlockedPaymentReports
GET {{baseUrl}}/trip-reports/blocked-payments
Authorization: Bearer {{accessToken}}

### Obtener reportes con documentos incompletos
# @name getIncompleteDocsReports
GET {{baseUrl}}/trip-reports/incomplete-documents
Authorization: Bearer {{accessToken}}

### Obtener estadísticas de reportes
# @name getTripReportStats
GET {{baseUrl}}/trip-reports/stats
Authorization: Bearer {{accessToken}}

### Respuesta esperada:
# {
#   "success": true,
#   "data": {
#     "total": 50,
#     "withCompleteDocs": 35,
#     "withBlockedPayments": 15,
#     "byPaymentStatus": {
#       "pending": 30,
#       "partial": 5,
#       "paid": 15
#     },
#     "totalFreightAmount": 60000.00,
#     "totalRetentionAmount": 4200.00,
#     "totalNetAmount": 55800.00
#   }
# }

### Actualizar un reporte
# @name updateTripReport
PUT {{baseUrl}}/trip-reports/{{tripReportId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "documentsComplete": true,
  "documentsPending": 0,
  "missingDocuments": null,
  "isPaymentBlocked": false
}

