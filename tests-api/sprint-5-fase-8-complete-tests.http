### Obtener tramos activos
# @name getActiveTramos
GET {{baseUrl}}/tramos/active
Authorization: Bearer {{accessToken}}

### Obtener tramos por origen
# @name getTramosByOrigin
GET {{baseUrl}}/tramos/by-origin/Matarani
Authorization: Bearer {{accessToken}}

### Obtener tramos por destino
# @name getTramosByDestination
GET {{baseUrl}}/tramos/by-destination/Cochabamba
Authorization: Bearer {{accessToken}}

### Obtener orígenes disponibles
# @name getOrigins
GET {{baseUrl}}/tramos/origins
Authorization: Bearer {{accessToken}}

### Respuesta esperada:
# {
#   "success": true,
#   "data": ["Matarani", "Arica", "Ilo"]
# }

### Obtener destinos disponibles
# @name getDestinations
GET {{baseUrl}}/tramos/destinations
Authorization: Bearer {{accessToken}}

### Obtener un tramo por ID
# @name getTramoById
GET {{baseUrl}}/tramos/{{tramoId}}
Authorization: Bearer {{accessToken}}

### Obtener un tramo por código
# @name getTramoByCode
GET {{baseUrl}}/tramos/code/MAT-CBA
Authorization: Bearer {{accessToken}}

### Crear un nuevo tramo
# @name createTramo
POST {{baseUrl}}/tramos
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "code": "ILO-SCZ",
  "name": "Ilo - Santa Cruz",
  "origin": "Ilo",
  "destination": "Santa Cruz",
  "distanceKm": 1100.00,
  "estimatedHours": 24,
  "baseRateUsd": 1600.00
}

### Respuesta esperada:
# {
#   "success": true,
#   "status": "success",
#   "message": "Tramo creado correctamente",
#   "data": {
#     "id": "uuid",
#     "code": "ILO-SCZ",
#     "name": "Ilo - Santa Cruz",
#     ...
#   }
# }

### Actualizar un tramo
# @name updateTramo
PUT {{baseUrl}}/tramos/{{tramoId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "baseRateUsd": 1650.00,
  "notes": "Ruta actualizada con nueva tarifa"
}

### Obtener estadísticas de tramos
# @name getTramoStats
GET {{baseUrl}}/tramos/stats
Authorization: Bearer {{accessToken}}

