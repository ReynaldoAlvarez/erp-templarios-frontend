### Obtener sanciones activas
# @name getActiveSanctions
GET {{baseUrl}}/sanctions/active
Authorization: Bearer {{accessToken}}

### Obtener sanciones por conductor
# @name getSanctionsByDriver
GET {{baseUrl}}/sanctions/driver/{{driverId}}
Authorization: Bearer {{accessToken}}

### Obtener estadísticas de sanciones
# @name getSanctionStats
GET {{baseUrl}}/sanctions/stats
Authorization: Bearer {{accessToken}}

### Crear sanción manual
# @name createSanction
POST {{baseUrl}}/sanctions
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "driverId": "{{driverId}}",
  "type": "WARNING",
  "reason": "SAFETY_VIOLATION",
  "notes": "Violación de normas de seguridad en la carga"
}

### Actualizar sanción
# @name updateSanction
PUT {{baseUrl}}/sanctions/{{sanctionId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "notes": "Notas actualizadas",
  "amount": 150.00
}

### Completar sanción
# @name completeSanction
POST {{baseUrl}}/sanctions/{{sanctionId}}/complete
Authorization: Bearer {{accessToken}}

### Cancelar sanción
# @name cancelSanction
POST {{baseUrl}}/sanctions/{{sanctionId}}/cancel
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "reason": "Sanción cancelada por error en el proceso"
}

