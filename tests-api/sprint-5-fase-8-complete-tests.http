Authorization: Bearer {{accessToken}}

### ==========================================
### CRITERIOS DE ACEPTACIÓN - VERIFICACIÓN
### ==========================================

### CA-001: Verificar que crear viaje genera documentos automáticamente
# Ejecutar primero: crear un viaje nuevo y verificar que se crearon los documentos
# @name verifyCA001
GET {{baseUrl}}/trip-reports?tripId={{newTripId}}
Authorization: Bearer {{accessToken}}

### CA-002: Verificar que camiones de apoyo tienen FACTURA en checklist
# @name verifyCA002
GET {{baseUrl}}/document-automation/trips/{{supportTruckTripId}}/checklist
Authorization: Bearer {{accessToken}}

### CA-003: Verificar que documentos incompletos bloquean pago
# @name verifyCA003
GET {{baseUrl}}/payment-block/can-process/{{settlementWithIncompleteDocs}}
Authorization: Bearer {{accessToken}}

### CA-004: Verificar rechazo de MIC/DTA duplicado
# Intentar crear un viaje con MIC/DTA existente debe retornar error 409

### CA-005: Verificar TripReport con todos los campos
# @name verifyCA005
GET {{baseUrl}}/trip-reports/{{tripReportId}}
Authorization: Bearer {{accessToken}}

### CA-006: Verificar generación automática de sanciones
# @name verifyCA006
POST {{baseUrl}}/sanctions/generate-automatic
Authorization: Bearer {{accessToken}}

### CA-007: Verificar retención configurable
# @name verifyCA007
GET {{baseUrl}}/settlements/{{settlementId}}
Authorization: Bearer {{accessToken}}

### CA-008: Verificar tramos disponibles
# @name verifyCA008
GET {{baseUrl}}/tramos/active
Authorization: Bearer {{accessToken}}
