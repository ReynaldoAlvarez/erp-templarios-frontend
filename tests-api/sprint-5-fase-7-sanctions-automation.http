###############################################################################
# SPRINT 5 - FASE 7: AUTOMATIZACIÓN DE SANCIONES
# Módulo de Generación Automática de Sanciones por Retraso en Documentación
###############################################################################
#
# ⚠️ IMPORTANTE: Antes de probar estos endpoints:
# 1. Ejecutar el seed: npx ts-node prisma/seed.ts
# 2. Tener viajes con pagos bloqueados (más de 3 días de retraso)
# 3. Los viajes deben ser de flota propia (no de apoyo)
#
# Permisos requeridos:
# - sanciones:sanciones:leer - Ver sanciones
# - sanciones:sanciones:crear - Crear sanciones manuales
# - sanciones:sanciones:actualizar - Actualizar/completar sanciones
# - sanciones:automatizacion:leer - Ver configuración y estadísticas
# - sanciones:automatizacion:crear - Generar sanciones automáticas
#
# El usuario admin@templarios.com tiene el rol Super Admin con TODOS los permisos.
###############################################################################

@baseUrl = http://localhost:3001/api/v1
@contentType = application/json

###############################################################################
# VARIABLES - REEMPLAZAR CON IDs DEL SEED
###############################################################################

# Conductor de flota propia (para pruebas)
@driverId = REPLACE_WITH_DRIVER_ID_FROM_SEED

# ID de una sanción existente
@sanctionId = REPLACE_WITH_SANCTION_ID_FROM_SEED

###############################################################################
# AUTENTICACIÓN
###############################################################################

### Login como admin
# @name login
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
  "email": "admin@templarios.com",
  "password": "Admin123!"
}

### Guardar token de acceso
@accessToken = {{login.response.body.data.accessToken}}

###############################################################################
# CONFIGURACIÓN Y CATÁLOGOS
###############################################################################

### Obtener configuración de sanciones automáticas
# @name getConfig
GET {{baseUrl}}/sanctions/config
Authorization: Bearer {{accessToken}}

###
# Response esperado:
# {
#   "success": true,
#   "data": {
#     "GRACE_PERIOD_DAYS": 3,
#     "FINE_PER_DAY_USD": 10,
#     "MAX_FINE_DAYS": 30,
#     "MAX_FINE_AMOUNT": 300,
#     "SUSPENSION_THRESHOLDS": {
#       "OFFENSE_COUNT": 3,
#       "OFFENSE_PERIOD_DAYS": 30,
#       "SUSPENSION_DAYS": 7
#     }
#   },
#   "message": "Configuración de sanciones obtenida"
# }

### Obtener razones de sanción disponibles
# @name getReasons
GET {{baseUrl}}/sanctions/reasons
Authorization: Bearer {{accessToken}}

###
# Response esperado:
# {
#   "success": true,
#   "data": [
#     { "value": "DOCUMENT_DELAY", "label": "Retraso en documentación", "description": "Sanción por entrega tardía de documentos" },
#     { "value": "REPEATED_OFFENSE", "label": "Ofensa repetida", "description": "Sanción por reincidencia en faltas" },
#     { "value": "SAFETY_VIOLATION", "label": "Violación de seguridad", "description": "Sanción por incumplimiento de normas de seguridad" },
#     { "value": "OTHER", "label": "Otra razón", "description": "Otra razón no especificada" }
#   ],
#   "message": "Razones de sanción obtenidas"
# }

### Obtener tipos de sanción
# @name getTypes
GET {{baseUrl}}/sanctions/types
Authorization: Bearer {{accessToken}}

###
# Response esperado:
# {
#   "success": true,
#   "data": [
#     { "value": "FINE", "label": "Multa" },
#     { "value": "SUSPENSION", "label": "Suspensión" },
#     { "value": "WARNING", "label": "Amonestación" }
#   ],
#   "message": "Tipos de sanción obtenidos correctamente"
# }

###############################################################################
# VIAJES CON RETRASO DE DOCUMENTACIÓN
###############################################################################

### Obtener todos los viajes con retraso
# @name getDelayedTrips
GET {{baseUrl}}/sanctions/delayed-trips
Authorization: Bearer {{accessToken}}

###
# Response esperado:
# {
#   "success": true,
#   "data": {
#     "trips": [
#       {
#         "tripId": "uuid-trip",
#         "micDta": "MIC-2024-001",
#         "driverId": "uuid-driver",
#         "driverName": "Juan Pérez",
#         "truckPlate": "ABC-123",
#         "isSupportTruck": false,
#         "settlementId": "uuid-settlement",
#         "missingDocuments": ["MIC", "BALANZA"],
#         "daysDelayed": 5,
#         "shouldSanction": true
#       }
#     ],
#     "total": 1
#   },
#   "message": "Viajes con retraso obtenidos correctamente"
# }

### Obtener viajes con mínimo de días de retraso
GET {{baseUrl}}/sanctions/delayed-trips?minDaysDelayed=5
Authorization: Bearer {{accessToken}}

### Obtener viajes con retraso de un conductor específico
GET {{baseUrl}}/sanctions/delayed-trips?driverId={{driverId}}
Authorization: Bearer {{accessToken}}

###############################################################################
# GENERACIÓN AUTOMÁTICA DE SANCIONES
###############################################################################

### Generar sanciones automáticas para todos los viajes con retraso
# @name generateAutomatic
POST {{baseUrl}}/sanctions/generate-automatic
Authorization: Bearer {{accessToken}}

###
# Response esperado (sanciones generadas):
# {
#   "success": true,
#   "data": {
#     "generated": 3,
#     "skipped": 2,
#     "alreadySanctioned": 1,
#     "sanctions": [
#       {
#         "id": "uuid-sanction",
#         "driverId": "uuid-driver",
#         "driverName": "Juan Pérez",
#         "tripId": "uuid-trip",
#         "micDta": "MIC-2024-001",
#         "daysDelayed": 5,
#         "amount": 50,
#         "type": "FINE"
#       }
#     ],
#     "errors": []
#   },
#   "message": "Proceso completado: 3 sanciones generadas, 2 omitidas, 1 ya tenían sanción"
# }

###############################################################################
# VERIFICACIÓN DE REINCIDENCIA
###############################################################################

### Verificar reincidencia de un conductor
# @name checkRecurring
GET {{baseUrl}}/sanctions/check-recurring/{{driverId}}
Authorization: Bearer {{accessToken}}

###
# Response esperado (sin suspensión):
# {
#   "success": true,
#   "data": {
#     "shouldSuspend": false,
#     "recentSanctions": 1,
#     "suspensionDays": 0,
#     "nextOffenseCount": 2
#   },
#   "message": "Verificación de reincidencia completada"
# }

###
# Response esperado (con suspensión):
# {
#   "success": true,
#   "data": {
#     "shouldSuspend": true,
#     "recentSanctions": 3,
#     "suspensionDays": 7,
#     "nextOffenseCount": 0
#   },
#   "message": "Verificación de reincidencia completada"
# }

###############################################################################
# PROCESAR SANCIONES DE CONDUCTOR ESPECÍFICO
###############################################################################

### Procesar sanciones de un conductor específico
# @name processDriver
POST {{baseUrl}}/sanctions/process-driver/{{driverId}}
Authorization: Bearer {{accessToken}}

###
# Response esperado (sin suspensión):
# {
#   "success": true,
#   "data": {
#     "newSanctions": 1,
#     "suspensionGenerated": false
#   },
#   "message": "Procesado: 1 nuevas sanciones."
# }

###
# Response esperado (con suspensión):
# {
#   "success": true,
#   "data": {
#     "newSanctions": 1,
#     "suspensionGenerated": true,
#     "suspensionDays": 7,
#     "result": {
#       "sanction": { ... },
#       "driver": { "id": "uuid", "name": "Juan Pérez" }
#     }
#   },
#   "message": "Procesado: 1 nuevas sanciones. Suspensión generada por 7 días."
# }

###############################################################################
# ESTADÍSTICAS
###############################################################################

### Obtener estadísticas de automatización
# @name getAutomationStats
GET {{baseUrl}}/sanctions/automation-stats
Authorization: Bearer {{accessToken}}

###
# Response esperado:
# {
#   "success": true,
#   "data": {
#     "total": 15,
#     "automatic": 10,
#     "manual": 5,
#     "byReason": {
#       "DOCUMENT_DELAY": 8,
#       "REPEATED_OFFENSE": 4,
#       "OTHER": 3
#     },
#     "totalFines": 1500.00,
#     "pendingFines": 500.00,
#     "averageDaysDelayed": 5,
#     "driversWithMultipleSanctions": 3
#   },
#   "message": "Estadísticas de automatización obtenidas"
# }

### Obtener estadísticas de un conductor específico
GET {{baseUrl}}/sanctions/automation-stats?driverId={{driverId}}
Authorization: Bearer {{accessToken}}

### Obtener estadísticas generales de sanciones
# @name getStats
GET {{baseUrl}}/sanctions/stats
Authorization: Bearer {{accessToken}}

###
# Response esperado:
# {
#   "success": true,
#   "data": {
#     "total": 15,
#     "active": 8,
#     "totalFines": 1500.00,
#     "byType": {
#       "FINE": 10,
#       "SUSPENSION": 3,
#       "WARNING": 2
#     },
#     "byStatus": {
#       "PENDING": 8,
#       "COMPLETED": 5,
#       "CANCELLED": 2
#     }
#   },
#   "message": "Estadísticas de sanciones obtenidas correctamente"
# }

###############################################################################
# CRUD DE SANCIONES
###############################################################################

### Listar todas las sanciones
# @name getAll
GET {{baseUrl}}/sanctions?page=1&limit=10
Authorization: Bearer {{accessToken}}

###
# Response esperado:
# {
#   "success": true,
#   "data": {
