###############################################################################
# CREAR SANCIÓN MANUAL
###############################################################################

### Crear una multa manual
# @name createFine
POST {{baseUrl}}/sanctions
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "driverId": "{{driverId}}",
  "type": "FINE",
  "reason": "Incumplimiento de horario de entrega",
  "amount": 100,
  "notes": "El conductor no cumplió con el horario establecido para la entrega de documentación"
}

###
# Response esperado:
# {
#   "success": true,
#   "data": {
#     "id": "uuid-new-sanction",
#     "driverId": "uuid-driver",
#     "type": "FINE",
#     "reason": "Incumplimiento de horario de entrega",
#     "sanctionReason": "OTHER",
#     "amount": 100.00,
#     "startDate": "2024-04-01T00:00:00Z",
#     "status": "PENDING",
#     "automatic": false,
#     "driver": {
#       "employee": {
#         "firstName": "Juan",
#         "lastName": "Pérez"
#       }
#     }
#   },
#   "message": "Sanción creada correctamente"
# }

### Crear una suspensión manual
POST {{baseUrl}}/sanctions
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "driverId": "{{driverId}}",
  "type": "SUSPENSION",
  "reason": "Violación repetida de normas de seguridad",
  "startDate": "2024-04-01",
  "endDate": "2024-04-08",
  "notes": "Suspensión de 7 días por reincidencia en violaciones de seguridad"
}

###
# Response esperado:
# {
#   "success": true,
#   "data": {
#     "id": "uuid-new-sanction",
#     "driverId": "uuid-driver",
#     "type": "SUSPENSION",
#     "reason": "Violación repetida de normas de seguridad",
#     "startDate": "2024-04-01T00:00:00Z",
#     "endDate": "2024-04-08T00:00:00Z",
#     "status": "PENDING",
#     "automatic": false
#   },
#   "message": "Sanción creada correctamente"
# }

### Crear una amonestación
POST {{baseUrl}}/sanctions
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "driverId": "{{driverId}}",
  "type": "WARNING",
  "reason": "Primera falta en presentación de documentación",
  "notes": "Amonestación verbal - se advierte sobre consecuencias de reincidencia"
}

###############################################################################
# ACTUALIZAR SANCIÓN
###############################################################################

### Actualizar una sanción existente
PUT {{baseUrl}}/sanctions/{{sanctionId}}
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "reason": "Razón actualizada con más detalles",
  "amount": 75,
  "notes": "Monto reducido tras apelación del conductor"
}

###
# Response esperado:
# {
#   "success": true,
#   "data": {
#     "id": "uuid-sanction",
#     "reason": "Razón actualizada con más detalles",
#     "amount": 75.00,
#     "notes": "Monto reducido tras apelación del conductor"
#   },
#   "message": "Sanción actualizada correctamente"
# }

###############################################################################
# COMPLETAR Y CANCELAR SANCIÓN
###############################################################################

### Completar una sanción
POST {{baseUrl}}/sanctions/{{sanctionId}}/complete
Authorization: Bearer {{accessToken}}

###
# Response esperado:
# {
#   "success": true,
#   "data": {
#     "id": "uuid-sanction",
#     "status": "COMPLETED",
#     "endDate": "2024-04-01T00:00:00Z"
#   },
#   "message": "Sanción completada correctamente"
# }

### Cancelar una sanción
POST {{baseUrl}}/sanctions/{{sanctionId}}/cancel
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "reason": "La documentación fue entregada fuera de plazo pero con justificación válida"
}

###
# Response esperado:
# {
#   "success": true,
#   "data": {
#     "id": "uuid-sanction",
#     "status": "CANCELLED",
#     "notes": "Notas anteriores\nCancelada: La documentación fue entregada fuera de plazo pero con justificación válida"
#   },
#   "message": "Sanción cancelada correctamente"
# }

###############################################################################
# ERRORES COMUNES
###############################################################################

### Error: Token no proporcionado
GET {{baseUrl}}/sanctions

###
# Response esperado:
# {
#   "success": false,
#   "status": "fail",
#   "message": "Token de acceso requerido",
#   "code": "UNAUTHORIZED"
# }

### Error: ID de sanción no encontrado
GET {{baseUrl}}/sanctions/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{accessToken}}

###
# Response esperado:
# {
#   "success": false,
#   "status": "fail",
#   "message": "Sanción no encontrada",
#   "code": "NOT_FOUND"
# }

### Error: Conductor no encontrado al crear sanción
POST {{baseUrl}}/sanctions
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "driverId": "00000000-0000-0000-0000-000000000000",
  "type": "FINE",
  "reason": "Test"
}

###
# Response esperado:
# {
#   "success": false,
#   "status": "fail",
#   "message": "Conductor no encontrado",
#   "code": "NOT_FOUND"
# }

### Error: Suspensión sin fecha de fin
POST {{baseUrl}}/sanctions
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "driverId": "{{driverId}}",
  "type": "SUSPENSION",
  "reason": "Suspensión sin fecha de fin"
}

###
# Response esperado:
# {
#   "success": false,
#   "status": "fail",
#   "message": "Las suspensiones deben tener fecha de fin",
#   "code": "VALIDATION_ERROR"
# }

###############################################################################
# FLUJO COMPLETO DE AUTOMATIZACIÓN
###############################################################################

### 1. Verificar configuración
# GET {{baseUrl}}/sanctions/config

### 2. Ver viajes con retraso
# GET {{baseUrl}}/sanctions/delayed-trips?minDaysDelayed=3

### 3. Generar sanciones automáticas
# POST {{baseUrl}}/sanctions/generate-automatic

### 4. Verificar reincidencia de conductores afectados
# GET {{baseUrl}}/sanctions/check-recurring/{{driverId}}

### 5. Consultar estadísticas
# GET {{baseUrl}}/sanctions/automation-stats

### 6. Completar sanciones según corresponda
# POST {{baseUrl}}/sanctions/{{sanctionId}}/complete
