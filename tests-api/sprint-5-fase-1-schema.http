# ============================================================================
# SPRINT 5 - FASE 1: SCHEMA CHANGES
# ============================================================================
# Tests para verificar los cambios en el schema de base de datos
# 
# IMPORTANTE: Este archivo documenta las respuestas esperadas para el frontend
# después de aplicar la migración del Sprint 5 Fase 1
# ============================================================================

@baseUrl = http://localhost:3001/api/v1
@token = {{login.response.body.data.token}}

# ============================================================================
# AUTENTICACIÓN
# ============================================================================

### Login - Obtener token
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@templarios.com",
  "password": "Admin123!"
}

# ============================================================================
# RESPUESTA ESPERADA (Login):
# ============================================================================
# {
#   "success": true,
#   "message": "Login exitoso",
#   "data": {
#     "token": "eyJhbGciOiJIUzI1NiIs...",
#     "refreshToken": "eyJhbGciOiJIUzI1NiIs...",
#     "user": {
#       "id": "uuid",
#       "email": "admin@templarios.com",
#       "firstName": "Super",
#       "lastName": "Admin",
#       "company": {
#         "id": "uuid",
#         "name": "TEMPLARIOS S.R.L.",
#         "companyName": "TEMPLARIOS S.R.L.",  // ← NUEVO: Nombre comercial
#         "companyType": "OWN"                  // ← NUEVO: Tipo de empresa
#       },
#       "roles": [
#         {
#           "id": "uuid",
#           "name": "Super Admin"
#         }
#       ]
#     }
#   }
# }
