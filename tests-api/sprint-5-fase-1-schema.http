### Listar documentos requeridos para camiones propios
# @name getRequiredDocumentsOwn
GET {{baseUrl}}/document-types?filter=required&isForSupportOnly=false
Authorization: Bearer {{token}}

# ============================================================================
# RESPUESTA ESPERADA (Documentos para camiones propios):
# ============================================================================
# Retorna solo documentos donde isForSupportOnly = false
# {
#   "success": true,
#   "data": [
#     { "code": "MIC", "name": "Manifiesto Internacional de Carga", ... },
#     { "code": "CRT", "name": "Carta de Porte", ... },
#     { "code": "ASPB", "name": "Autorización de Servicio de Transporte de Carga", ... },
#     { "code": "NOTA_TARJA", "name": "Nota de Tarja", ... },
#     { "code": "BALANZA", "name": "Comprobante de Balanza", ... }
#   ],
#   "meta": { "total": 5 }
# }
# ============================================================================

### Listar documentos requeridos para camiones de apoyo
# @name getRequiredDocumentsSupport
GET {{baseUrl}}/document-types?filter=required
Authorization: Bearer {{token}}

# ============================================================================
# RESPUESTA ESPERADA (Documentos para camiones de apoyo):
# ============================================================================
# Retorna TODOS los documentos incluyendo FACTURA
# {
#   "success": true,
#   "data": [
#     { "code": "MIC", ... },
#     { "code": "CRT", ... },
#     { "code": "ASPB", ... },
#     { "code": "NOTA_TARJA", ... },
#     { "code": "BALANZA", ... },
#     { "code": "FACTURA", ... }    // ← Incluido para apoyo
#   ],
#   "meta": { "total": 6 }
# }
# ============================================================================

