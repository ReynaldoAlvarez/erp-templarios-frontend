###############################################################################
# VERIFICACIÓN Y ACTUALIZACIÓN DE ESTADO DE BLOQUEO
###############################################################################

### Verificar y actualizar estado de bloqueo de un viaje
# Usa el tripId bloqueado definido arriba
POST {{baseUrl}}/payment-block/check/{{blockedTripId}}
Authorization: Bearer {{accessToken}}

###
# Response esperado (documentos completos):
# {
#   "success": true,
#   "data": {
#     "tripId": "uuid-trip",
#     "documentsComplete": true,
#     "isPaymentBlocked": false,
#     "blockReason": null,
#     "missingDocuments": [],
#     "previousState": {
#       "documentsComplete": false,
#       "isPaymentBlocked": true
#     },
#     "notificationSent": true
#   },
#   "message": "Pago desbloqueado. Documentos completos."
# }

###
# Response esperado (documentos incompletos):
# {
#   "success": true,
#   "data": {
#     "tripId": "uuid-trip",
#     "documentsComplete": false,
#     "isPaymentBlocked": true,
#     "blockReason": "Documentos faltantes: MIC, BALANZA",
#     "missingDocuments": ["MIC", "BALANZA"],
#     "previousState": {
#       "documentsComplete": true,
#       "isPaymentBlocked": false
#     },
#     "notificationSent": true
#   },
#   "message": "Pago bloqueado. Faltan documentos: MIC, BALANZA"
# }

###############################################################################
# VERIFICAR SI SE PUEDE PROCESAR PAGO
###############################################################################

### Verificar si un pago bloqueado puede ser procesado (debe retornar false)
GET {{baseUrl}}/payment-block/can-process/{{blockedSettlementId}}
Authorization: Bearer {{accessToken}}

###
# Response esperado (puede procesarse):
# {
#   "success": true,
#   "data": {
#     "canProcess": true,
#     "reason": null,
#     "missingDocuments": []
#   }
# }

###
# Response esperado (no puede procesarse):
# {
#   "success": true,
#   "data": {
#     "canProcess": false,
#     "reason": "Documentos faltantes: MIC, BALANZA",
#     "missingDocuments": ["MIC", "BALANZA"]
#   }
# }

###############################################################################
# DESBLOQUEO MANUAL DE PAGO
###############################################################################

### Desbloquear manualmente un pago bloqueado
# Usa el settlementId bloqueado definido arriba
POST {{baseUrl}}/payment-block/unblock/{{blockedSettlementId}}
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "reason": "Documento original extraviado. Se cuenta con copia legalizada y autorización del cliente para proceder con el pago."
}

###
# Response esperado:
# {
#   "success": true,
#   "data": {
