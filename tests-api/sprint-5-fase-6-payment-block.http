###############################################################################
# SPRINT 5 - FASE 6: PAYMENT BLOCK MODULE
# Módulo de Bloqueo de Pagos por Documentación Incompleta
###############################################################################
#
# ⚠️ IMPORTANTE: Antes de probar estos endpoints:
# 1. Ejecutar el seed: npx ts-node prisma/seed.ts
# 2. El seed mostrará los IDs de settlements bloqueados y desbloqueados
# 3. Copiar los IDs mostrados en la salida del seed a las variables abaixo
#
# Permisos requeridos:
# - pagos:bloqueo:listar - Ver lista de pagos bloqueados
# - pagos:bloqueo:leer - Ver detalles y estadísticas
# - pagos:bloqueo:actualizar - Actualizar estado de bloqueo
# - pagos:bloqueo:desbloquear - Desbloqueo manual
#
# El usuario admin@templarios.com tiene el rol Super Admin con TODOS los permisos.
###############################################################################

@baseUrl = http://localhost:3001/api/v1
@contentType = application/json

###############################################################################
# VARIABLES - REEMPLAZAR CON IDs DEL SEED
# Después de ejecutar el seed, copiar los IDs aquí:
###############################################################################

# Trip bloqueado (con documentos pendientes)
#@blockedTripId = REPLACE_WITH_TRIP_ID_FROM_SEED
@blockedTripId = 2f481335-0814-4055-8afd-56bc826bca0b
# Settlement bloqueado (para pruebas de desbloqueo)
#@blockedSettlementId = REPLACE_WITH_SETTLEMENT_ID_FROM_SEED
@blockedSettlementId =84354d96-2933-4de2-84ea-f0bb7128674f
# Settlement desbloqueado (para pruebas de can-process)
#@unblockedSettlementId = REPLACE_WITH_SETTLEMENT_ID_FROM_SEED
@unblockedSettlementId = ca29eecb-6a3d-407f-8aae-266398b953b7

###############################################################################
# AUTENTICACIÓN
###############################################################################

### Login como admin
# @name login
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
  "email": "admin@templarios.com",
  "password": "Admin123!"
}

### Guardar token de acceso
@accessToken = {{login.response.body.data.accessToken}}

###############################################################################
# ESTADÍSTICAS DE PAGOS BLOQUEADOS
###############################################################################

### Obtener estadísticas de bloqueo de pagos
# @name getStats
GET {{baseUrl}}/payment-block/stats
Authorization: Bearer {{accessToken}}

###
# Response esperado:
# {
#   "success": true,
#   "data": {
#     "total": 50,
#     "blocked": 10,
#     "unblocked": 40,
#     "blockedPercentage": 20,
#     "totalBlockedAmount": 50000.00,
#     "byDriver": [
#       {
#         "driverId": "uuid",
#         "driverName": "Juan Pérez",
#         "blockedCount": 3,
#         "totalAmount": 15000.00
#       }
#     ],
#     "byMissingDocument": [
#       {
#         "code": "MIC",
#         "name": "Manifiesto Internacional de Carga",
#         "count": 5
#       },
#       {
#         "code": "BALANZA",
#         "name": "Comprobante de Balanza",
#         "count": 3
#       }
#     ],
#     "avgBlockedDays": 3
#   }
# }

###############################################################################
# LISTA DE PAGOS BLOQUEADOS
###############################################################################

### Obtener lista de pagos bloqueados (sin filtros)
# @name getBlockedPayments
GET {{baseUrl}}/payment-block/blocked
Authorization: Bearer {{accessToken}}

###
# Response esperado:
# {
#   "success": true,
#   "data": {
#     "settlements": [
#       {
#         "id": "uuid-settlement",
#         "netPayment": 5000.00,
#         "status": "PENDING",
#         "isPaymentBlocked": true,
#         "documentsComplete": false,
#         "blockedDays": 5,
#         "missingDocuments": [
#           {
#             "code": "MIC",
#             "name": "Manifiesto Internacional de Carga",
#             "status": "PENDING"
#           }
#         ],
#         "trip": {
#           "id": "uuid-trip",
#           "micDta": "MIC-123",
#           "driver": {
#             "id": "uuid-driver",
#             "employee": {
#               "firstName": "Juan",
#               "lastName": "Pérez",
#               "phone": "+591 71234567"
#             }
#           },
#           "truck": {
#             "plateNumber": "ABC-123",
#             "isSupportTruck": false
#           },
#           "billOfLading": {
#             "blNumber": "BL-2024-001"
#           }
#         },
#         "createdAt": "2024-03-28T10:00:00Z"
#       }
#     ],
#     "total": 10,
#     "page": 1,
#     "limit": 10,
#     "totalPages": 1
#   }
# }

### Obtener pagos bloqueados con paginación
GET {{baseUrl}}/payment-block/blocked?page=1&limit=5
Authorization: Bearer {{accessToken}}

### Obtener pagos bloqueados filtrados por conductor
GET {{baseUrl}}/payment-block/blocked?driverId=uuid-driver-123
Authorization: Bearer {{accessToken}}

### Obtener pagos bloqueados filtrados por rango de fechas
GET {{baseUrl}}/payment-block/blocked?dateFrom=2024-01-01&dateTo=2024-12-31
Authorization: Bearer {{accessToken}}

###############################################################################
# CHECKLIST DE DOCUMENTOS CON ESTADO DE PAGO
###############################################################################

### Obtener checklist de documentos de un viaje bloqueado
# Usa el tripId bloqueado definido arriba
GET {{baseUrl}}/payment-block/checklist/{{blockedTripId}}
Authorization: Bearer {{accessToken}}

