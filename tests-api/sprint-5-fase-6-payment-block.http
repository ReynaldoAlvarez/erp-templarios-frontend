# }

###
# Error esperado (settlement no bloqueado):
# {
#   "success": false,
#   "error": {
#     "message": "La liquidación no está bloqueada",
#     "statusCode": 400
#   }
# }

###
# Error esperado (motivo muy corto):
# {
#   "success": false,
#   "error": {
#     "message": "El motivo del desbloqueo debe tener al menos 10 caracteres",
#     "statusCode": 400
#   }
# }

###############################################################################
# PROCESAR TODOS LOS PENDIENTES
###############################################################################

### Procesar verificación de todos los viajes pendientes
POST {{baseUrl}}/payment-block/process-all
Authorization: Bearer {{accessToken}}

###
# Response esperado:
# {
#   "success": true,
#   "data": {
#     "processed": 50,
#     "blocked": 10,
#     "unblocked": 40,
#     "errors": []
#   },
#   "message": "Procesados 50 settlements: 10 bloqueados, 40 desbloqueados"
# }

###############################################################################
# HISTORIAL DE BLOQUEOS
###############################################################################

### Obtener historial de bloqueos de un settlement
GET {{baseUrl}}/payment-block/history/{{blockedSettlementId}}
Authorization: Bearer {{accessToken}}

###
# Response esperado:
# {
#   "success": true,
#   "data": {
#     "settlementId": "uuid-settlement",
#     "currentStatus": {
#       "isPaymentBlocked": false,
#       "documentsComplete": true
#     },
#     "history": [
#       {
#         "action": "MANUAL_UNBLOCK",
#         "userId": "uuid-user",
#         "userName": "Admin User",
#         "timestamp": "2024-03-28T10:00:00Z",
#         "details": {
#           "isPaymentBlocked": false,
#           "reason": "Documento extraviado, se procede con el pago"
#         }
#       }
#     ]
#   }
# }

###############################################################################
# INTEGRACIÓN CON SETTLEMENTS - VALIDACIÓN DE BLOQUEO
###############################################################################

### Intentar aprobar una liquidación bloqueada (debe fallar)
POST {{baseUrl}}/settlements/{{blockedSettlementId}}/approve
Authorization: Bearer {{accessToken}}

###
# Error esperado:
# {
#   "success": false,
#   "error": {
#     "message": "No se puede aprobar la liquidación. Documentos faltantes: MIC, BALANZA. Complete la documentación o solicite un desbloqueo manual.",
#     "statusCode": 400
#   }
# }

### Intentar pagar una liquidación bloqueada (debe fallar)
POST {{baseUrl}}/settlements/{{blockedSettlementId}}/pay
Authorization: Bearer {{accessToken}}

###
# Error esperado:
# {
#   "success": false,
#   "error": {
#     "message": "No se puede procesar el pago. Documentos faltantes: MIC, BALANZA. Complete la documentación o solicite un desbloqueo manual.",
#     "statusCode": 400
#   }
# }

###############################################################################
# FLUJO COMPLETO DE VERIFICACIÓN
###############################################################################

### 1. Verificar estado actual de documentos
# GET {{baseUrl}}/payment-block/checklist/{{blockedTripId}}

### 2. Verificar si el pago puede procesarse
# GET {{baseUrl}}/payment-block/can-process/{{blockedSettlementId}}

### 3. Si está bloqueado, verificar documentos y actualizar estado
# POST {{baseUrl}}/payment-block/check/{{blockedTripId}}

### 4. Si aún bloqueado y es necesario, desbloquear manualmente
# POST {{baseUrl}}/payment-block/unblock/{{blockedSettlementId}}
# Body: { "reason": "..." }

### 5. Intentar aprobar/pagar nuevamente
# POST {{baseUrl}}/settlements/{{blockedSettlementId}}/approve
# POST {{baseUrl}}/settlements/{{blockedSettlementId}}/pay

###############################################################################
# CASOS DE ERROR COMUNES
###############################################################################

### Error: Token no proporcionado
GET {{baseUrl}}/payment-block/stats

###
# Response esperado:
# {
#   "success": false,
#   "error": {
#     "message": "Token de acceso requerido",
#     "statusCode": 401
#   }
# }

### Error: Permisos insuficientes
# Usar un token de usuario sin permisos de pagos:bloqueo:leer
GET {{baseUrl}}/payment-block/stats
Authorization: Bearer {{accessToken}}

###
# Response esperado:
# {
#   "success": false,
#   "error": {
#     "message": "No tiene permisos para realizar esta acción",
#     "statusCode": 403
#   }
# }

### Error: ID de viaje inválido
GET {{baseUrl}}/payment-block/checklist/invalid-id
Authorization: Bearer {{accessToken}}

###
# Response esperado:
# {
#   "success": false,
#   "error": {
#     "message": "Errores de validación",
#     "details": ["El ID del viaje debe ser un UUID válido"],
#     "statusCode": 400
#   }
# }

### Error: Viaje no encontrado
GET {{baseUrl}}/payment-block/checklist/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{accessToken}}

###
# Response esperado:
# {
#   "success": false,
#   "error": {
#     "message": "Viaje con ID 00000000-0000-0000-0000-000000000000 no encontrado",
#     "statusCode": 404
#   }
# }
