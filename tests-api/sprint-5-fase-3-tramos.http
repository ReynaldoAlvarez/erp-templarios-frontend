###     "createdAt": "2026-03-30T01:02:57.662Z",
###     "updatedAt": "2026-03-30T12:18:00.000Z"
###   },
###   "timestamp": "2026-03-30T12:18:00.000Z"
### }

### 4.2 Actualizar tarifa
# @name updateRate
PUT {{baseUrl}}/tramos/{{tramoId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "baseRateUsd": 1250.00,
  "baseRateBob": 8750.00
}

### 📤 RESPUESTA ESPERADA: Similar a 4.1 con tarifas actualizadas

### 4.3 Actualizar distancia y tiempo
# @name updateDistance
PUT {{baseUrl}}/tramos/{{tramoId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "distanceKm": 850.00,
  "estimatedHours": 19
}

### 📤 RESPUESTA ESPERADA: Similar a 4.1 con distancia y tiempo actualizados

### 4.4 Actualizar múltiples campos
# @name updateMultiple
PUT {{baseUrl}}/tramos/{{tramoId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Matarani - Cochabamba",
  "distanceKm": 845.50,
  "estimatedHours": 18,
  "baseRateUsd": 1200.00,
  "notes": "Ruta principal para importaciones desde Perú"
}

### 📤 RESPUESTA ESPERADA: Similar a 4.1 con todos los campos actualizados

