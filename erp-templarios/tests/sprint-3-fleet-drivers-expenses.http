###############################################################################
# 11. CONDUCTORES (DRIVERS) - CRUD BÁSICO
###############################################################################

### 11.1 Listar Conductores - Éxito (paginado)
# @name listDrivers
GET {{baseUrl}}/drivers?page=1&limit=10
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

###

### 11.2 Listar Conductores - Con búsqueda
# @name listDriversSearch
GET {{baseUrl}}/drivers?search=Juan
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

###

### 11.3 Listar Conductores - Filtrar por disponibilidad
# @name listDriversAvailable
GET {{baseUrl}}/drivers?isAvailable=true
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

###

### 11.4 Listar Conductores - Filtrar por tipo de contrato
# @name listDriversByContract
GET {{baseUrl}}/drivers?contractType=MONTHLY
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

###

### 11.5 Crear Conductor - Éxito
# @name createDriver
POST {{baseUrl}}/drivers
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "firstName": "Juan",
  "lastName": "Pérez Mamani",
  "identityCard": "12345678 LP",
  "phone": "+591 71234567",
  "email": "juan.perez@templarios.com",
  "address": "Zona Norte, La Paz",
  "licenseNumber": "LIC-2024-001",
  "licenseCategory": "A",
  "licenseExpiryDate": "2025-12-31",
  "contractType": "MONTHLY",
  "branchId": "default-branch-id"
}

###

### 11.6 Crear Conductor - Fallido (Cédula duplicada)
# @name createDriverDuplicateCI
POST {{baseUrl}}/drivers
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "firstName": "Pedro",
  "lastName": "Gómez",
  "identityCard": "12345678 LP",
  "licenseNumber": "LIC-2024-002",
  "branchId": "default-branch-id"
}

###
# Expected: 409 Conflict - "Ya existe un empleado con esta cédula de identidad"

