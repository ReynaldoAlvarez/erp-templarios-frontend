POST {{baseUrl}}/drivers
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "firstName": "Pedro",
  "lastName": "Gómez",
  "identityCard": "87654321 LP",
  "licenseNumber": "LIC-2024-001",
  "branchId": "default-branch-id"
}

###
